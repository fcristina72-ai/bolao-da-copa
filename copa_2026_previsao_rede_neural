    "def build_model():\n",
    "    in_t1 = tf.keras.Input(shape=(), dtype=\"int32\", name=\"team1\")\n",
    "    in_t2 = tf.keras.Input(shape=(), dtype=\"int32\", name=\"team2\")\n",
    "    in_n  = tf.keras.Input(shape=(len(NUM_FEATS),), dtype=\"float32\", name=\"num\")\n",
    "    emb_atk = tf.keras.layers.Embedding(NTEAMS, 8, name=\"atk\")\n",
    "    emb_def = tf.keras.layers.Embedding(NTEAMS, 8, name=\"def\")\n",
    "    f = tf.keras.layers.Flatten()\n",
    "    x = tf.keras.layers.Concatenate()(\n",
    "        [f(emb_atk(in_t1)), f(emb_def(in_t1)),\n",
    "         f(emb_atk(in_t2)), f(emb_def(in_t2)), in_n])\n",
    "    x = tf.keras.layers.Dense(64, activation=\"relu\",\n",
    "            kernel_regularizer=tf.keras.regularizers.l2(1e-4))(x)\n",
    "    x = tf.keras.layers.Dropout(0.3)(x)\n",
    "    x = tf.keras.layers.Dense(32, activation=\"relu\")(x)\n",
    "    x = tf.keras.layers.Dropout(0.2)(x)\n",
    "    lam1 = tf.keras.layers.Dense(1, activation=\"exponential\", name=\"lam1\")(x)\n",
    "    lam2 = tf.keras.layers.Dense(1, activation=\"exponential\", name=\"lam2\")(x)\n",
    "    out  = tf.keras.layers.Concatenate(name=\"lams\")([lam1, lam2])\n",
    "    m = tf.keras.Model([in_t1, in_t2, in_n], out)\n",
    "    m.compile(optimizer=tf.keras.optimizers.Adam(1e-3),\n",
    "              loss=tf.keras.losses.Poisson())\n",
    "    return m\n",
    "\n",
    "model = build_model()\n",
    "es = tf.keras.callbacks.EarlyStopping(patience=15, restore_best_weights=True,\n",
    "                                      monitor=\"val_loss\")\n",
    "h = model.fit(Xtr, ytr, sample_weight=w_tr, validation_data=(Xva, yva),\n",
    "              epochs=200, batch_size=256, callbacks=[es], verbose=0)\n",
    "print(f\"Epochs: {len(h.history['loss'])} | melhor val_loss: {min(h.history['val_loss']):.4f}\")\n",
    "model.summary()"
