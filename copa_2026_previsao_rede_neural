    "def best_scoreline(l1, l2, maxg=8):\n",
    "    g = np.arange(0, maxg+1)\n",
    "    P = np.outer(poisson.pmf(g, l1), poisson.pmf(g, l2)); P /= P.sum()\n",
    "    pres = {\"1\": np.tril(P,-1).sum(), \"X\": np.trace(P), \"2\": np.triu(P,1).sum()}\n",
    "    rfun = lambda a,b: \"1\" if a>b else (\"X\" if a==b else \"2\")\n",
    "    best, bev = (0,0), -1\n",
    "    for a in g:\n",
    "        for b in g:\n",
    "            ev = 3.0*P[a,b] + 2.0*pres[rfun(a,b)]\n",
    "            if ev > bev: bev, best = ev, (int(a), int(b))\n",
    "    return best, bev, pres\n",
    "\n",
    "def score_pred(pa,pb,ra,rb):\n",
    "    if pa==ra and pb==rb: return 5\n",
    "    rp = \"1\" if pa>pb else (\"X\" if pa==pb else \"2\")\n",
    "    rr = \"1\" if ra>rb else (\"X\" if ra==rb else \"2\")\n",
    "    return 2 if rp==rr else 0\n",
    "\n",
    "def elo_baseline(d):\n",
    "    return (1,1) if abs(d)<40 else ((1,0) if d>0 else (0,1))\n",
    "\n",
    "lam_va = model.predict(Xva, verbose=0)\n",
    "pm=p11=pelo=0.0\n",
    "for k in range(len(va)):\n",
    "    (pa,pb),_,_ = best_scoreline(*lam_va[k])\n",
    "    ra,rb = int(yva[k][0]), int(yva[k][1])\n",
    "    pm   += score_pred(pa,pb,ra,rb)\n",
    "    p11  += score_pred(1,1,ra,rb)\n",
    "    eb = elo_baseline(va.iloc[k][\"elo_diff\"]); pelo += score_pred(eb[0],eb[1],ra,rb)\n",
    "N=len(va)\n",
    "print(f\"Validacao ({N} jogos) — pontos medios/jogo:\")\n",
    "print(f\"  Rede neural : {pm/N:.3f}\")\n",
    "print(f\"  Baseline 1x1: {p11/N:.3f}\")\n",
    "print(f\"  Baseline Elo: {pelo/N:.3f}\")"
   ]
