    "NTEAMS = len(teams)\n",
    "assert all(SIGLA2NAME[s] in team2idx for s in SIGLA2NAME)\n",
    "\n",
    "NUM_FEATS = [\"elo1\",\"elo2\",\"elo_diff\",\"home1\",\"gf1\",\"ga1\",\"gf2\",\"ga2\"]\n",
    "mu = train_df[NUM_FEATS].mean(); sd = train_df[NUM_FEATS].std().replace(0,1)\n",
    "\n",
    "def make_xy(d):\n",
    "    Xn = ((d[NUM_FEATS]-mu)/sd).values.astype(\"float32\")\n",
    "    return ([d[\"home_team\"].map(team2idx).values.astype(\"int32\"),\n",
