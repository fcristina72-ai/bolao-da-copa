    "def k_factor(t):\n",
    "    t = str(t)\n",
    "    if t == \"FIFA World Cup\": return 60.0\n",
    "    if t in (\"Copa America\",\"UEFA Euro\",\"African Cup of Nations\",\n",
    "             \"AFC Asian Cup\",\"Gold Cup\",\"Confederations Cup\"): return 50.0\n",
    "    if \"qualif\" in t.lower() or \"Nations League\" in t: return 40.0\n",
    "    if t == \"Friendly\": return 20.0\n",
    "    return 30.0\n",
    "\n",
    "def goal_mult(gd):\n",
    "    gd = abs(gd)\n",
    "    if gd <= 1: return 1.0\n",
    "    if gd == 2: return 1.5\n",
    "    return (11.0 + gd) / 8.0\n",
    "\n",
    "HOME_ADV = 65.0\n",
    "elo, hist = {}, {}\n",
    "def get_elo(t): return elo.get(t, 1500.0)\n",
    "def form(t):\n",
    "    gs = hist.get(t, [])\n",
    "    if not gs: return 1.2, 1.2\n",
    "    return (np.mean([x[0] for x in gs[-10:]]), np.mean([x[1] for x in gs[-10:]]))\n",
    "\n",
    "cols = {k: np.zeros(len(df)) for k in [\"elo1\",\"elo2\",\"gf1\",\"ga1\",\"gf2\",\"ga2\"]}\n",
    "for i, r in enumerate(df.itertuples(index=False)):\n",
    "    h, a = r.home_team, r.away_team\n",
    "    eh, ea = get_elo(h), get_elo(a)\n",
    "    cols[\"elo1\"][i], cols[\"elo2\"][i] = eh, ea\n",
    "    cols[\"gf1\"][i], cols[\"ga1\"][i] = form(h)\n",
    "    cols[\"gf2\"][i], cols[\"ga2\"][i] = form(a)\n",
    "    ha = 0.0 if r.neutral else HOME_ADV\n",
    "    we = 1.0 / (1.0 + 10 ** (-((eh + ha) - ea) / 400.0))\n",
    "    gd = r.home_score - r.away_score\n",
    "    w = 1.0 if gd > 0 else (0.5 if gd == 0 else 0.0)\n",
    "    k = k_factor(r.tournament) * goal_mult(gd)\n",
    "    elo[h] = eh + k * (w - we)\n",
    "    elo[a] = ea + k * ((1 - w) - (1 - we))\n",
    "    hist.setdefault(h, []).append((r.home_score, r.away_score))\n",
    "    hist.setdefault(a, []).append((r.away_score, r.home_score))\n",
    "\n",
    "for k, v in cols.items(): df[k] = v\n",
    "df[\"elo_diff\"] = df[\"elo1\"] - df[\"elo2\"]\n",
    "df[\"home1\"]    = (~df[\"neutral\"]).astype(float)\n",
    "print(\"Top Elo atual:\")\n",
    "print(pd.Series(elo).sort_values(ascending=False).head(8).round(0))"
   ]
